program: statement*

?statement: assignment
          | module_def
          | function_def
          | module_call
          | if_statement
          | for_statement
          | let_statement
          | use_statement
          | include_statement
          | ";"

assignment: name "=" expr ";"
          | SPECIAL_VAR "=" expr ";"
          | name "=" "let" "(" let_assignments ")" expr ";"
          | SPECIAL_VAR "=" "let" "(" let_assignments ")" expr ";"

module_def: "module" name "(" param_list? ")" "{" statement* "}"
          | "module" name "(" param_list? ")" module_call
          | "module" name "(" param_list? ")" ";"

function_def: "function" name "(" param_list? ")" "=" expr ";"

param_list: param ("," param)* ","?

param: name ("=" expr)?
     | SPECIAL_VAR ("=" expr)?

module_call: modifier? module_name "(" arg_list? ")" "{" statement* "}" ";"?
           | modifier? module_name "(" arg_list? ")" statement

modifier: "!" | "#" | "%" | "*"

module_name: name

arg_list: arg ("," arg?)*

arg: name "=" expr
   | SPECIAL_VAR "=" expr
   | expr

if_statement: "if" "(" expr ")" "{" statement* "}" "else" "{" statement* "}"
            | "if" "(" expr ")" "{" statement* "}" "else" statement
            | "if" "(" expr ")" "{" statement* "}"
            | "if" "(" expr ")" statement "else" "{" statement* "}"
            | "if" "(" expr ")" statement "else" statement
            | "if" "(" expr ")" statement

for_statement: "for" "(" for_assignments ")" "{" statement* "}"
             | "for" "(" for_assignments ")" statement
             | "intersection_for" "(" for_assignments ")" "{" statement* "}"
             | "intersection_for" "(" for_assignments ")" statement

for_assignments: for_assignment ("," for_assignment)*

for_assignment: name "=" expr

let_statement: "let" "(" let_assignments ")" "{" statement* "}"
             | "let" "(" let_assignments ")" statement

let_assignments: let_assignment ("," let_assignment)*

let_assignment: name "=" expr

use_statement: "use" USE_PATH ";"?

include_statement: "include" USE_PATH ";"?

?expr: ternary_expr

?ternary_expr: or_expr "?" ternary_expr ":" ternary_expr
             | or_expr

?or_expr: or_expr "||" and_expr
        | and_expr

?and_expr: and_expr "&&" comp_expr
         | comp_expr

?comp_expr: comp_expr "==" add_expr
          | comp_expr "!=" add_expr
          | comp_expr "<" add_expr
          | comp_expr ">" add_expr
          | comp_expr "<=" add_expr
          | comp_expr ">=" add_expr
          | add_expr

?add_expr: add_expr "+" mul_expr
         | add_expr "-" mul_expr
         | mul_expr

?mul_expr: mul_expr "*" unary_expr
         | mul_expr "/" unary_expr
         | mul_expr "%" unary_expr
         | unary_expr

?unary_expr: "-" unary_expr
           | "!" unary_expr
           | "+" unary_expr
           | postfix_expr

?postfix_expr: postfix_expr "[" expr "]"
             | postfix_expr "." name
             | primary_expr

?primary_expr: NUMBER
             | ESCAPED_STRING
             | "true" -> true_literal
             | "false" -> false_literal
             | "undef" -> undef_literal
             | name "(" arg_list? ")" -> function_call
             | name
             | SPECIAL_VAR
             | list_expr
             | range_expr
             | list_comp
             | "(" expr ")"

list_expr: "[" "]"
         | "[" list_items "]"

list_items: expr ("," expr)* ","?

range_expr: "[" expr ":" expr "]"
          | "[" expr ":" expr ":" expr "]"

list_comp: "[" comp_for "]"
         | "[" comp_if "]"
         | "[" comp_let "]"
         | "[" comp_each "]"

comp_for: "for" "(" for_assignments ")" comp_element

comp_if: "if" "(" expr ")" comp_element "else" comp_element
       | "if" "(" expr ")" comp_element

comp_let: "let" "(" let_assignments ")" comp_element

comp_each: "each" comp_element

?comp_element: comp_for
             | comp_if
             | comp_let
             | comp_each
             | expr

?name: IDENTIFIER
     | DIGIT_IDENTIFIER

SPECIAL_VAR: /\$[a-zA-Z_][a-zA-Z0-9_]*/

USE_PATH: "<" /[^>]+/ ">"

COMMENT: /\/\/[^\n]*/
       | /\/\*[\s\S]*?\*\//

IDENTIFIER: /[a-zA-Z_][a-zA-Z0-9_]*/

DIGIT_IDENTIFIER.3: /[0-9]+[a-zA-Z_][a-zA-Z0-9_]*/

NUMBER: /[0-9]+\.?[0-9]*([eE][+-]?[0-9]+)?/
      | /\.[0-9]+([eE][+-]?[0-9]+)?/

%import common.ESCAPED_STRING

%ignore /[ \t\n\r]+/
%ignore COMMENT
